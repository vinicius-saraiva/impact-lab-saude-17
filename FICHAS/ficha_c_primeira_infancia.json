          { "id": "p4_vacinacao_em_dia", "label": "4) Vacinação em dia? (0-6 anos)", "tipo": "enum", "visivel_se": "idade_meses <= 72", "enum_ref": "_shared.enums.sim_nao" },
          { "id": "p5_alimentacao", "label": "5) Como está a alimentação da criança? (0-6 anos)", "tipo": "enum", "visivel_se": "idade_meses <= 72", "enum_ref": "_shared.enums.alimentacao_crianca" },
          { "id": "p6_sinais_risco", "label": "6) Sinais de risco? (0-6 anos)", "tipo": "multi_enum", "visivel_se": "idade_meses <= 72", "enum_ref": "_shared.enums.sinais_risco_crianca" },
          { "id": "p7_alteracao_desenvolvimento", "label": "7) A mãe percebeu algum problema/alteração no desenvolvimento? (0-6 anos)", "tipo": "enum", "visivel_se": "idade_meses <= 72", "enum_ref": "_shared.enums.sim_nao" },
          { "id": "p8_perfil_bpc_nao_recebendo", "label": "8) Criança com perfil de BPC, mas ainda não está recebendo? (0-6 anos)", "tipo": "enum", "visivel_se": "idade_meses <= 72", "enum_ref": "_shared.enums.sim_nao", "descricao": "Encaminhar para assistente social se SIM" },
          { "id": "p9_comida_acabou", "label": "9) No último mês, a comida acabou antes que tivesse dinheiro? (0-6 anos)", "tipo": "enum", "visivel_se": "idade_meses <= 72", "enum_ref": "_shared.enums.sim_nao", "descricao": "Triagem segurança alimentar" },

          { "id": "p10_creche_pre_escola", "label": "10) A criança está matriculada na creche ou pré-escola? Qual? (6m-6anos)", "tipo": "enum", "visivel_se": "idade_meses >= 6 E idade_meses <= 72", "enum_ref": "_shared.enums.sim_nao" },
          { "id": "p10_nome_instituicao", "label": "10) Nome da creche/pré-escola", "tipo": "string", "obrigatorio_condicional": "p10_creche_pre_escola == 'S'", "max_length": 120 },
          { "id": "p11_faltou_creche", "label": "11) Criança faltou por algum motivo? Qual? (6m-6anos)", "tipo": "enum", "visivel_se": "idade_meses >= 6 E idade_meses <= 72", "enum_ref": "_shared.enums.sim_nao" },
          { "id": "p11_motivo_falta", "label": "11) Motivo da falta", "tipo": "text", "obrigatorio_condicional": "p11_faltou_creche == 'S'", "max_length": 200 },

          { "id": "p12_contraturno", "label": "12) A criança tem acesso à atividade de contraturno? (4-6 anos)", "tipo": "enum", "visivel_se": "idade_meses >= 48 E idade_meses <= 72", "enum_ref": "_shared.enums.sim_nao" },

