  "regras_negocio": [
    { "id": "RN001", "descricao": "TDO = visita diária obrigatória durante todo o período de tratamento (regra DOCX SMS-Rio)", "tipo": "cadencia" },
    { "id": "RN002", "descricao": "Falha consecutiva > 2 dias em registrar dose → ALERTA — risco de abandono", "tipo": "downstream" },
    { "id": "RN003", "descricao": "P1 == 'S' (continua tossindo) após 2º mês → encaminhamento médico — possível resistência", "tipo": "downstream" },
    { "id": "RN004", "descricao": "P2 inclui sinais hepatotóxicos (urina escura, pele amarelada) → URGÊNCIA — possível hepatite medicamentosa", "tipo": "downstream" },
    { "id": "RN005", "descricao": "P3 == 'S' (resistência a tomar remédio) → bundle de adesão + envolver família", "tipo": "downstream" },
    { "id": "RN006", "descricao": "P4 > 0 (contatos não examinados) → busca ativa imediata dos contatos", "tipo": "downstream" },
    { "id": "RN007", "descricao": "Escarro mensal NÃO realizado nos meses 2 e 5 → encaminhamento prioritário (controle obrigatório)", "tipo": "downstream" },
    { "id": "RN008", "descricao": "Após 2 meses de TDO sem nova baciloscopia → flag de risco", "tipo": "downstream" },
    { "id": "RN009", "descricao": "Paciente em população de rua → estratégia TDO diferenciada (busca ativa em pontos)", "tipo": "downstream" },
    { "id": "RN010", "descricao": "Status final pode ser: Cura, Abandono, Óbito, Transferência, Falência, Mudança de diagnóstico", "tipo": "structural" }
  ],

